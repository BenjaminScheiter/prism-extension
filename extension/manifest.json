{
  "manifest_version": 3,
  "name": "Prism 1.0.46",
  "version": "1.0.46",
  "description": "Make prompt tokens more valuable: preserve intent, remove waste, add only necessary structure, protect exact artifacts, and measure value per token.",
  "action": {
    "default_title": "Prism 1.0.46",
    "default_icon": {
      "16": "assets/icons/prism-16.png",
      "32": "assets/icons/prism-32.png",
      "48": "assets/icons/prism-48.png",
      "128": "assets/icons/prism-128.png"
    },
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "assets/icons/prism-16.png",
    "32": "assets/icons/prism-32.png",
    "48": "assets/icons/prism-48.png",
    "128": "assets/icons/prism-128.png"
  },
  "options_page": "src/options.html",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://gemini.google.com/*",
        "https://*.gemini.google.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://kimi.com/*",
        "https://*.kimi.com/*"
      ],
      "js": [
        "src/prism-core.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-bridge.js"
      ],
      "use_dynamic_url": true,
      "matches": [
        "https://*/*"
      ]
    }
  ]
}
